generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum LeadStatus {
  INQUIRY
  CONFIRMED
  BOOKED
  CANCELLED
  NO_ANSWER
  NOT_INTERESTED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(AGENT)
  avatarHue     Int       @default(295)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedLeads Lead[]    @relation("AssignedLeads")
}

model LeadSource {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String
  apiKeyHash  String   @unique
  apiKeyHint  String
  origin      String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  leads       Lead[]
}

model Lead {
  id          String     @id @default(cuid())
  fullName    String
  phone       String
  city        String
  status      LeadStatus @default(INQUIRY)
  notesCount  Int        @default(0)

  sourceId    String
  source      LeadSource @relation(fields: [sourceId], references: [id])

  assigneeId  String?
  assignee    User?      @relation("AssignedLeads", fields: [assigneeId], references: [id])

  submittedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([sourceId, submittedAt])
  @@index([status])
  @@index([assigneeId])
  @@index([city])
}
