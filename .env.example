# Neon Postgres (or any Postgres) connection strings. DATABASE_URL should be
# the pooled URL (works with serverless), DIRECT_DATABASE_URL the direct one
# (needed for migrations and shadow DB).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth. Generate with: openssl rand -base64 32
AUTH_SECRET="<32-byte base64>"
AUTH_URL="http://localhost:3000"

# Initial admin user created by `prisma db seed`.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"
ADMIN_NAME="Mahadahlan Admin"

# Comma-separated origins allowed to POST to /api/leads (CORS allowlist).
LANDING_ORIGINS="http://localhost:3000,https://mahadahlan.com"
